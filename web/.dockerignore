# .dockerignore for the web image (context = ./web).
node_modules/
.next/
next-env.d.ts
*.tsbuildinfo

# Secrets — NEXT_PUBLIC_* are passed as build args, never via a committed .env.
.env
.env.*
!.env.example

# VCS / editor / OS
.git/
.gitignore
.DS_Store
.idea/
.vscode/

# Design docs not needed in the build. NOTE: design/tokens.css IS needed — globals.css
# imports it (@import "../design/tokens.css"), so design/ must NOT be excluded.
DESIGN_NOTES.md
