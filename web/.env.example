# Mimik Suite — web/ frontend environment
#
# Two auth paths coexist:
#   1. Supabase (real per-user auth) — the login flow. Read SERVER-SIDE ONLY (no
#      NEXT_PUBLIC_ prefix) so the anon key and issued tokens never enter the client bundle.
#   2. Dev bootstrap token (NEXT_PUBLIC_DEV_TOKEN) — a DEV-ONLY fallback for rendering the
#      board without logging in. Inlined into the client bundle, so NEVER a prod credential.

# ---- API ----
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---- Supabase (server-side; login flow) ----
# Must match the SAME Supabase project the FastAPI backend verifies against
# (api/core/supabase_auth.py). No trailing slash.
SUPABASE_URL=
# The anon/publishable key. Public by design, but kept server-side here (no NEXT_PUBLIC_).
SUPABASE_ANON_KEY=

# ---- Dev-only fallback ----
# First-party HS256 bootstrap token minted by POST /tenants. Used to render the board
# WITHOUT a Supabase login, and ONLY when APP_ENV is unset/"dev". Leave empty in prod.
NEXT_PUBLIC_DEV_TOKEN=
# Set to a non-dev value (e.g. "prod") to DISABLE the dev-token board fallback and force
# Supabase login. Unset or "dev" keeps the fallback available.
APP_ENV=dev
