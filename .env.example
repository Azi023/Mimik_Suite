# Copy to .env and fill in. NEVER commit .env.
# Grouped by the phase that first needs each value — prep as much as you can up front so the
# build loop never stalls mid-phase. "PREP NOW" = create the account/key before starting.

# ============ Core (P0 — works with these defaults) ============
# compose maps Postgres to host 5434, Redis to 6381 (5432/6379 taken by other local services)
DATABASE_URL=postgresql+asyncpg://mimik:mimik@localhost:5434/mimik_suite
REDIS_URL=redis://localhost:6381/0
APP_ENV=dev
LOG_LEVEL=info
# P0 scaffolding auth (replaced by Supabase in P3). >=32 chars.
JWT_SECRET=dev-only-insecure-change-me-0000000000
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MIN=60

# ============ P2 — copy (TEXT) via free Gemini API ============
# PREP NOW: Google AI Studio -> Create API key (Free tier is fine for TEXT/copy).
# NOTE: the free tier does NOT reliably include IMAGE generation — that's why images use the
# browser path below, not this key.
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-flash-latest   # always-current free Flash; pinned IDs can 404 per-key
LEONARDO_BROWSER_PROFILE_DIR=           # persistent Chromium profile for the Leonardo.ai session (default var/browser/leonardo); bootstrap: scripts/leonardo_login.py

# ============ P2 — imagery (IMAGES) ============
# Route by cost/reliability. Set IMAGE_BACKEND_PRIMARY to whichever you got working.
#
# NO FREE IMAGE PATH EXISTS (all confirmed dead): ChatGPT browser = Cloudflare-blocked;
# AI-Studio browser = fails; free Gemini image API = HTTP 429 (no free image quota).
# => DEV/TEST render with PLACEHOLDER backgrounds (image_ref=None, FREE). Paid gen only for
#    real deliverables. These browser dirs are kept only if a workaround is ever found.
AISTUDIO_BROWSER_PROFILE_DIR=
CHATGPT_BROWSER_PROFILE_DIR=
#
# (b) PAID API path — robust, no browser, ~pennies/image. Recommended for hero/best quality.
#     OpenAI — use the BEST tier for real deliverables (operator preference), not a low tier:
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2   # top tier; confirm the exact id is live for your key before first paid run
#     OR Gemini image API (enable billing on the same GEMINI_API_KEY — key already lists the models):
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
#     OpenRouter (flexible fallback — text or specific models; ~$3 budget, use SPARINGLY):
OPENROUTER_API_KEY=
#
IMAGE_BACKEND_PRIMARY=none   # 'none' = placeholder solid backgrounds for dev/test (FREE, no gen)
IMAGE_BACKEND_HERO=gpt_image # paid backend for REAL deliverables only: gpt_image | openrouter | gemini_image
#
# HARD SPEND GUARD (~$8 total credits, operator-gated): must be EXACTLY 1 to permit any paid
# image call — every paid adapter refuses otherwise. Leave empty for all dev/test.
MIMIK_ALLOW_PAID_IMAGES=

# ============ P3 — auth (Supabase) ============
# Managed auth: Supabase issues tokens, the API only VERIFIES them. Modern projects sign with
# asymmetric keys (ES256/RS256) served at {SUPABASE_URL}/auth/v1/.well-known/jwks.json — the
# API derives that URL from SUPABASE_URL automatically; no secret needed for that path.
SUPABASE_URL=
SUPABASE_ANON_KEY=            # used by the web/ client SDK for login (public)
SUPABASE_SERVICE_ROLE_KEY=   # server-side admin ops (never sent to the browser)
# Only for LEGACY projects that still sign JWTs with the shared HS256 secret. Leave empty for
# asymmetric (JWKS) projects — the default. (Dashboard: Settings -> API -> JWT Secret.)
SUPABASE_JWT_SECRET=

# ============ P3 — archive backend (auto-archive on approval) ============
# Default 'local' needs NO credentials — writes to ARCHIVE_LOCAL_ROOT/Mimik Clients/<Client>/
# <YYYY-MM>/<job>/. The full approve->archive flow runs on this, zero manual upload.
ARCHIVE_BACKEND=local          # local | google_drive | google_drive_oauth
ARCHIVE_LOCAL_ROOT=./_archive  # where the local backend writes (gitignored)
#
# --- (A) WORKING PROD PATH: user OAuth (ARCHIVE_BACKEND=google_drive_oauth) ---
# Archives AS THE USER, so files are owned by the user and use the user's Drive quota — this is
# the path that actually uploads into a normal My-Drive folder. (The service-account path below
# CANNOT: Google returns 403 "Service Accounts do not have storage quota" for My-Drive folders;
# it only works against a Shared Drive.) Get the refresh token ONCE:
#   uv run --no-sync python scripts/drive_oauth.py
# (needs GOOGLE_OAUTH_CLIENT_ID + GOOGLE_OAUTH_CLIENT_SECRET set first; redirect_uri
#  http://localhost:8765 must be registered on the OAuth client). Secrets — never commit:
GOOGLE_OAUTH_CLIENT_ID=        # OAuth 2.0 Client ID (Desktop/Web) from Google Cloud console
GOOGLE_OAUTH_CLIENT_SECRET=    # its client secret (gitignored)
GOOGLE_OAUTH_REFRESH_TOKEN=    # printed by scripts/drive_oauth.py — paste it here (gitignored)
#
# --- (B) service account (ARCHIVE_BACKEND=google_drive) — Shared Drive only ---
# PREP a Google service account with access to a SHARED Drive folder. Both are required:
GOOGLE_SERVICE_ACCOUNT_JSON=   # the service-account JSON, or a path to the .json (gitignored)
#
# Required by BOTH Drive backends — the "Mimik Clients" root folder id:
DRIVE_ROOT_FOLDER_ID=          # the root Drive folder id (My-Drive folder for OAuth path)

# ============ P5 — billing (Stripe TEST mode) ============
# The billing code is BUILT + tested with mocked Stripe (no live calls). To turn it on, add
# your TEST-mode keys: /billing/checkout then refuses (503) until secret + price are set, and
# /billing/webhook refuses (503) until the webhook secret is set — no accidental live/charge.
STRIPE_SECRET_KEY=              # sk_test_...
STRIPE_WEBHOOK_SECRET=          # whsec_... (webhook endpoint, or `stripe listen`)
STRIPE_PRICE_ID=                # the $750/mo recurring price id (price_..., test mode)
BILLING_SUCCESS_URL=https://mimikcreations.com/unlimited/welcome
BILLING_CANCEL_URL=https://mimikcreations.com/unlimited
