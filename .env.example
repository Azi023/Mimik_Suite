# Copy to .env and fill in. NEVER commit .env.
# Grouped by the phase that first needs each value — prep as much as you can up front so the
# build loop never stalls mid-phase. "PREP NOW" = create the account/key before starting.

# ============ Core (P0 — works with these defaults) ============
# compose maps Postgres to host 5434, Redis to 6381 (5432/6379 taken by other local services)
DATABASE_URL=postgresql+asyncpg://mimik:mimik@localhost:5434/mimik_suite
REDIS_URL=redis://localhost:6381/0
APP_ENV=dev
LOG_LEVEL=info
# P0 scaffolding auth (replaced by Supabase in P3). >=32 chars.
JWT_SECRET=dev-only-insecure-change-me-0000000000
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MIN=60

# ============ P2 — copy (TEXT) via free Gemini API ============
# PREP NOW: Google AI Studio -> Create API key (Free tier is fine for TEXT/copy).
# NOTE: the free tier does NOT reliably include IMAGE generation — that's why images use the
# browser path below, not this key.
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash

# ============ P2 — imagery (IMAGES) via browser automation (your PRO subs, no tokens) ============
# PREP NOW: log into ChatGPT and/or Google AI Studio in a dedicated Chrome/Chromium profile,
# then point these at that profile dir so Playwright reuses the logged-in session.
# (Log in ONCE manually; automation reuses the cookies — never store passwords here.)
CHATGPT_BROWSER_PROFILE_DIR=
AISTUDIO_BROWSER_PROFILE_DIR=
IMAGE_BACKEND_PRIMARY=chatgpt_browser   # chatgpt_browser | aistudio_browser

# ============ P3 — auth (Supabase) ============
# PREP NOW (optional, unblocks P3 without a stop): create a Supabase project.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============ P3 — Drive archive (Google service account) ============
# PREP NOW (optional): a Google service account with access to a shared Drive folder.
GOOGLE_SERVICE_ACCOUNT_JSON=   # path to the service-account .json (gitignored)
DRIVE_ROOT_FOLDER_ID=          # the "Mimik Clients" shared folder id

# ============ P5 — billing (Stripe TEST mode) ============
# PREP LATER: Stripe account -> test keys. P5 pauses for these anyway.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=               # the $750/mo price id (test mode)
