# Secrets — NEVER commit
.env
.env.*
!.env.example
*.key
*.pem
*.p12
credentials*
*.secret
.keys
# Google service-account keys (Drive archive) — the JSON IS a credential
secure repo/
secure_repo/
*service-account*.json
*service_account*.json
gen-lang-client-*.json
gcp-*.json

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
dist/
build/

# Node / Next.js
node_modules/
.next/
out/
*.tsbuildinfo
.turbo/

# Data / runtime artifacts (may contain client PII)
runs/
outputs/
*.sqlite
*.db
uploads/
storage/
